# Copy this file to `.streamlit/secrets.toml` to ENABLE login. With no secrets the app
# runs with no authentication.
#
#   [access]  present  → login is required (email/password + admin approval)
#   [auth]    present  → ALSO offer "Log in with Google"
#
# Admins are always allowed and approve everyone else from the sidebar. Seed the first
# admin email(s) here; approvals afterwards are stored in gui_app/access.json. Email/password
# accounts (self sign-up) are stored bcrypt-hashed in gui_app/users.json and start pending.

[access]
admins = ["you@example.com"]

# --- Optional: Google (OIDC) login -----------------------------------------
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
#    (type: Web application).
# 2. Authorised redirect URI must match `redirect_uri` exactly, e.g.
#    http://localhost:8501/oauth2callback   (use your real host in production).
# 3. cookie_secret: any long random string
#    (`python -c "import secrets;print(secrets.token_hex(32))"`).
# Remove this whole [auth] block to offer email/password login only.
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "CHANGE_ME_to_a_long_random_string"
client_id = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
